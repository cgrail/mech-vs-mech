# mech-vs-mech — install.sh configuration (optional)
#
# Copy to .env next to install.sh; `sudo ./install.sh` reads it when
# DOMAIN/EMAIL aren't given on the command line. .env is gitignored and
# survives the auto-update timer's hard reset.
#
# DOMAIN — one or more hostnames Caddy should serve over HTTPS
# (Let's Encrypt), comma- or space-separated. Leave it empty (DOMAIN=)
# for Cloudflare mode: plain HTTP on port 80, locked to Cloudflare IPs.
DOMAIN=mech.grails.de,metschy.com

# EMAIL — optional, only used for Let's Encrypt expiry notices.
EMAIL=christian@grails.de

# Runtime tunables (ALLOWED_ORIGINS, MAX_CLIENTS, …) do NOT belong here —
# set them in /etc/default/mech-vs-mech (see the README's deployment table).
